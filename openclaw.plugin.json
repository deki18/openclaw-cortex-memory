{
  "id": "@openclaw/cortex-memory",
  "name": "Cortex Memory",
  "version": "0.2.0",
  "description": "Long-term memory system with semantic, episodic, and procedural memory for AI Agents",
  "author": "OpenClaw Community",
  "license": "MIT",
  "type": "memory",
  "repository": {
    "type": "git",
    "url": "https://github.com/deki18/openclaw-cortex-memory"
  },
  "capabilities": {
    "tools": true,
    "hooks": true,
    "cli": true,
    "channels": false,
    "memory": true
  },
  "hooks": [
    "message_received",
    "session_end",
    "timer"
  ],
  "tools": [
    {
      "name": "search_memory",
      "description": "Search long-term memory for relevant information",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query"
          },
          "top_k": {
            "type": "integer",
            "description": "Number of results to return"
          }
        },
        "required": ["query"]
      }
    },
    {
      "name": "store_event",
      "description": "Store a new event in memory",
      "parameters": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string",
            "description": "Event summary"
          },
          "entities": {
            "type": "array",
            "description": "Involved entities",
            "items": {
              "type": "string"
            }
          },
          "outcome": {
            "type": "string",
            "description": "Event outcome"
          },
          "relations": {
            "type": "array",
            "description": "Entity relationships",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["summary"]
      }
    },
    {
      "name": "query_graph",
      "description": "Query memory graph for entity relationships",
      "parameters": {
        "type": "object",
        "properties": {
          "entity": {
            "type": "string",
            "description": "Entity name"
          }
        },
        "required": ["entity"]
      }
    },
    {
      "name": "get_auto_context",
      "description": "Get relevant memories based on recent messages",
      "parameters": {
        "type": "object",
        "properties": {
          "include_hot": {
            "type": "boolean",
            "description": "Include hot context"
          }
        },
        "required": []
      }
    },
    {
      "name": "reflect_memory",
      "description": "Convert events into semantic knowledge",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "sync_memory",
      "description": "Import historical session data into memory",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "delete_memory",
      "description": "Delete a memory by ID",
      "parameters": {
        "type": "object",
        "properties": {
          "memory_id": {
            "type": "string",
            "description": "Memory ID"
          }
        },
        "required": ["memory_id"]
      }
    },
    {
      "name": "diagnostics",
      "description": "Check memory system status",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    }
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "apiUrl": {
        "type": "string",
        "description": "URL of the Cortex Memory Python API server",
        "default": "http://127.0.0.1:8765"
      },
      "autoSync": {
        "type": "boolean",
        "description": "Automatically sync memory on session end",
        "default": true
      },
      "autoReflect": {
        "type": "boolean",
        "description": "Automatically trigger reflection periodically",
        "default": false
      },
      "embedding": {
        "type": "object",
        "description": "Embedding model configuration"
      },
      "llm": {
        "type": "object",
        "description": "LLM configuration"
      },
      "reranker": {
        "type": "object",
        "description": "Reranker configuration"
      }
    }
  },
  "python": {
    "required": true,
    "version": ">=3.10",
    "dependencies": [
      "fastapi",
      "lancedb",
      "networkx",
      "openai",
      "pydantic",
      "pyyaml",
      "requests",
      "uvicorn"
    ]
  }
}
