{
  "id": "openclaw-cortex-memory",
  "name": "Cortex Memory",
  "version": "0.1.0-Alpha.17",
  "description": "Long-term memory system with semantic, episodic, and procedural memory for AI Agents",
  "main": "dist/index.js",
  "author": "deki18",
  "license": "MIT",
  "type": "memory",
  "repository": {
    "type": "git",
    "url": "https://github.com/deki18/openclaw-cortex-memory"
  },
  "capabilities": {
    "tools": true,
    "hooks": true,
    "cli": true,
    "channels": false,
    "memory": true
  },
  "hooks": [
    "message_received",
    "session_end"
  ],
  "tools": [
    {
      "name": "search_memory",
      "description": "Search long-term memory for relevant information",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query"
          },
          "top_k": {
            "type": "integer",
            "description": "Number of results to return"
          }
        },
        "required": ["query"],
        "additionalProperties": false
      }
    },
    {
      "name": "store_event",
      "description": "Store a new event in memory",
      "parameters": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string",
            "description": "Event summary"
          },
          "entities": {
            "type": "array",
            "description": "Involved entities",
            "items": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              ]
            }
          },
          "outcome": {
            "type": "string",
            "description": "Event outcome"
          },
          "relations": {
            "type": "array",
            "description": "Entity relationships",
            "items": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "properties": {
                    "source": {
                      "type": "string"
                    },
                    "target": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string"
                    }
                  },
                  "required": ["source", "target"],
                  "additionalProperties": false
                }
              ]
            }
          }
        },
        "required": ["summary"],
        "additionalProperties": false
      }
    },
    {
      "name": "query_graph",
      "description": "Query memory graph for entity relationships",
      "parameters": {
        "type": "object",
        "properties": {
          "entity": {
            "type": "string",
            "description": "Entity name"
          },
          "rel": {
            "type": "string",
            "description": "Optional relation type filter"
          },
          "dir": {
            "type": "string",
            "description": "Relation direction filter",
            "enum": ["incoming", "outgoing", "both"]
          },
          "path_to": {
            "type": "string",
            "description": "Find path from entity to this target entity"
          },
          "max_depth": {
            "type": "integer",
            "description": "Path query max depth (2~4)"
          }
        },
        "required": ["entity"],
        "additionalProperties": false
      }
    },
    {
      "name": "get_hot_context",
      "description": "Get hot memory context for current session",
      "parameters": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "description": "Maximum number of hot context items"
          }
        },
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "get_auto_context",
      "description": "Get relevant memories based on recent messages",
      "parameters": {
        "type": "object",
        "properties": {
          "include_hot": {
            "type": "boolean",
            "description": "Include hot context"
          }
        },
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "reflect_memory",
      "description": "Convert events into semantic knowledge",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "sync_memory",
      "description": "Import historical session data into memory",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "delete_memory",
      "description": "Delete a memory by ID",
      "parameters": {
        "type": "object",
        "properties": {
          "memory_id": {
            "type": "string",
            "description": "Memory ID"
          }
        },
        "required": ["memory_id"],
        "additionalProperties": false
      }
    },
    {
      "name": "diagnostics",
      "description": "Check memory system status",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": [],
        "additionalProperties": false
      }
    }
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "Enable or disable Cortex Memory plugin",
        "default": true
      },
      "apiUrl": {
        "type": "string",
        "description": "URL of the memory service API",
        "default": "http://localhost:8765"
      },
      "engineMode": {
        "type": "string",
        "description": "Memory engine mode",
        "enum": ["ts"],
        "default": "ts"
      },
      "dbPath": {
        "type": "string",
        "description": "Path to the memory database directory"
      },
      "autoSync": {
        "type": "boolean",
        "description": "Automatically sync memory on session end",
        "default": true
      },
      "autoReflect": {
        "type": "boolean",
        "description": "Automatically trigger reflection periodically",
        "default": false
      },
      "autoReflectIntervalMinutes": {
        "type": "integer",
        "description": "Auto reflection scan interval in minutes",
        "default": 30
      },
      "embedding": {
        "type": "object",
        "description": "Embedding model configuration",
        "properties": {
          "provider": {
            "type": "string",
            "description": "Embedding provider name"
          },
          "model": {
            "type": "string",
            "description": "Embedding model name"
          },
          "apiKey": {
            "type": "string",
            "description": "Embedding API key"
          },
          "baseURL": {
            "type": "string",
            "description": "Embedding API base URL"
          },
          "baseUrl": {
            "type": "string",
            "description": "Embedding API base URL (camelCase alias)"
          },
          "dimensions": {
            "type": "integer",
            "description": "Embedding dimensions"
          },
          "timeoutMs": {
            "type": "integer",
            "description": "Embedding request timeout in milliseconds",
            "default": 20000
          },
          "maxRetries": {
            "type": "integer",
            "description": "Maximum retry attempts for embedding requests",
            "default": 4
          }
        },
        "required": ["provider", "model", "apiKey", "baseURL"],
        "additionalProperties": false
      },
      "llm": {
        "type": "object",
        "description": "LLM configuration",
        "properties": {
          "provider": {
            "type": "string",
            "description": "LLM provider name"
          },
          "model": {
            "type": "string",
            "description": "LLM model name"
          },
          "apiKey": {
            "type": "string",
            "description": "LLM API key"
          },
          "baseURL": {
            "type": "string",
            "description": "LLM API base URL"
          },
          "baseUrl": {
            "type": "string",
            "description": "LLM API base URL (camelCase alias)"
          }
        },
        "required": ["provider", "model", "apiKey", "baseURL"],
        "additionalProperties": false
      },
      "reranker": {
        "type": "object",
        "description": "Reranker configuration",
        "properties": {
          "provider": {
            "type": "string",
            "description": "Reranker provider name"
          },
          "model": {
            "type": "string",
            "description": "Reranker model name"
          },
          "apiKey": {
            "type": "string",
            "description": "Reranker API key"
          },
          "baseURL": {
            "type": "string",
            "description": "Reranker API base URL"
          },
          "baseUrl": {
            "type": "string",
            "description": "Reranker API base URL (camelCase alias)"
          }
        },
        "required": ["provider", "model", "apiKey", "baseURL"],
        "additionalProperties": false
      },
      "fallbackToBuiltin": {
        "type": "boolean",
        "description": "Fallback to OpenClaw builtin memory when Cortex Memory fails",
        "default": true
      },
      "readFusion": {
        "type": "object",
        "description": "Post-rerank LLM fusion for multi-route retrieval results",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable LLM fusion after rerank",
            "default": true
          },
          "maxCandidates": {
            "type": "integer",
            "description": "Maximum reranked candidates used for fusion",
            "default": 10
          },
          "authoritative": {
            "type": "boolean",
            "description": "Return only fused authoritative memory package to agent",
            "default": true
          }
        },
        "additionalProperties": false
      },
      "memoryDecay": {
        "type": "object",
        "description": "Time-decay controls for retrieval ranking by event_type",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable event-type half-life decay in retrieval ranking",
            "default": true
          },
          "minFloor": {
            "type": "number",
            "description": "Minimum decay factor floor in [0,1]",
            "default": 0.15
          },
          "defaultHalfLifeDays": {
            "type": "number",
            "description": "Default half-life in days for unconfigured event types",
            "default": 90
          },
          "halfLifeByEventType": {
            "type": "object",
            "description": "Half-life days overrides by event_type",
            "additionalProperties": {
              "type": "number"
            }
          },
          "antiDecay": {
            "type": "object",
            "description": "Hit-frequency anti-decay controls",
            "properties": {
              "enabled": {
                "type": "boolean",
                "description": "Enable anti-decay boost for frequently hit memories",
                "default": true
              },
              "maxBoost": {
                "type": "number",
                "description": "Maximum multiplicative anti-decay boost (>=1)",
                "default": 1.6
              },
              "hitWeight": {
                "type": "number",
                "description": "Hit count to boost conversion weight",
                "default": 0.08
              },
              "recentWindowDays": {
                "type": "number",
                "description": "Recent hit window in days for freshness contribution",
                "default": 30
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
