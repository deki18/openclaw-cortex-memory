{
  "id": "openclaw-cortex-memory",
  "name": "Cortex Memory",
  "version": "0.1.0-Alpha.1",
  "description": "Long-term memory system with semantic, episodic, and procedural memory for AI Agents",
  "main": "dist/index.js",
  "author": "OpenClaw Community",
  "license": "MIT",
  "type": "memory",
  "repository": {
    "type": "git",
    "url": "https://github.com/deki18/openclaw-cortex-memory"
  },
  "capabilities": {
    "tools": true,
    "hooks": true,
    "cli": true,
    "channels": false,
    "memory": true
  },
  "hooks": [
    "message_received",
    "session_end"
  ],
  "tools": [
    {
      "name": "search_memory",
      "description": "Search long-term memory for relevant information",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query"
          },
          "top_k": {
            "type": "integer",
            "description": "Number of results to return"
          }
        },
        "required": ["query"],
        "additionalProperties": false
      }
    },
    {
      "name": "store_event",
      "description": "Store a new event in memory",
      "parameters": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string",
            "description": "Event summary"
          },
          "entities": {
            "type": "array",
            "description": "Involved entities",
            "items": {
              "type": "string"
            }
          },
          "outcome": {
            "type": "string",
            "description": "Event outcome"
          },
          "relations": {
            "type": "array",
            "description": "Entity relationships",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["summary"],
        "additionalProperties": false
      }
    },
    {
      "name": "query_graph",
      "description": "Query memory graph for entity relationships",
      "parameters": {
        "type": "object",
        "properties": {
          "entity": {
            "type": "string",
            "description": "Entity name"
          }
        },
        "required": ["entity"],
        "additionalProperties": false
      }
    },
    {
      "name": "get_hot_context",
      "description": "Get hot memory context for current session",
      "parameters": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "description": "Maximum number of hot context items"
          }
        },
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "get_auto_context",
      "description": "Get relevant memories based on recent messages",
      "parameters": {
        "type": "object",
        "properties": {
          "include_hot": {
            "type": "boolean",
            "description": "Include hot context"
          }
        },
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "reflect_memory",
      "description": "Convert events into semantic knowledge",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "sync_memory",
      "description": "Import historical session data into memory",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "delete_memory",
      "description": "Delete a memory by ID",
      "parameters": {
        "type": "object",
        "properties": {
          "memory_id": {
            "type": "string",
            "description": "Memory ID"
          }
        },
        "required": ["memory_id"],
        "additionalProperties": false
      }
    },
    {
      "name": "diagnostics",
      "description": "Check memory system status",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": [],
        "additionalProperties": false
      }
    }
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "Enable or disable Cortex Memory plugin",
        "default": true
      },
      "apiUrl": {
        "type": "string",
        "description": "URL of the memory service API",
        "default": "http://127.0.0.1:8765"
      },
      "engineMode": {
        "type": "string",
        "description": "Memory engine mode",
        "enum": ["ts"],
        "default": "ts"
      },
      "dbPath": {
        "type": "string",
        "description": "Path to the memory database directory"
      },
      "autoSync": {
        "type": "boolean",
        "description": "Automatically sync memory on session end",
        "default": true
      },
      "autoReflect": {
        "type": "boolean",
        "description": "Automatically trigger reflection periodically",
        "default": false
      },
      "embedding": {
        "type": "object",
        "description": "Embedding model configuration",
        "properties": {
          "provider": {
            "type": "string",
            "description": "Embedding provider name"
          },
          "model": {
            "type": "string",
            "description": "Embedding model name"
          },
          "apiKey": {
            "type": "string",
            "description": "Embedding API key"
          },
          "baseURL": {
            "type": "string",
            "description": "Embedding API base URL"
          },
          "baseUrl": {
            "type": "string",
            "description": "Embedding API base URL (camelCase alias)"
          },
          "dimensions": {
            "type": "integer",
            "description": "Embedding dimensions"
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "type": "object",
        "description": "LLM configuration",
        "properties": {
          "provider": {
            "type": "string",
            "description": "LLM provider name"
          },
          "model": {
            "type": "string",
            "description": "LLM model name"
          },
          "apiKey": {
            "type": "string",
            "description": "LLM API key"
          },
          "baseURL": {
            "type": "string",
            "description": "LLM API base URL"
          },
          "baseUrl": {
            "type": "string",
            "description": "LLM API base URL (camelCase alias)"
          }
        },
        "additionalProperties": false
      },
      "reranker": {
        "type": "object",
        "description": "Reranker configuration",
        "properties": {
          "provider": {
            "type": "string",
            "description": "Reranker provider name"
          },
          "model": {
            "type": "string",
            "description": "Reranker model name"
          },
          "apiKey": {
            "type": "string",
            "description": "Reranker API key"
          },
          "baseURL": {
            "type": "string",
            "description": "Reranker API base URL"
          },
          "baseUrl": {
            "type": "string",
            "description": "Reranker API base URL (camelCase alias)"
          }
        },
        "additionalProperties": false
      },
      "fallbackToBuiltin": {
        "type": "boolean",
        "description": "Fallback to OpenClaw builtin memory when Cortex Memory fails",
        "default": true
      }
    },
    "additionalProperties": false
  }
}
