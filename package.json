{
  "name": "@openclaw/cortex-memory",
  "version": "0.2.0",
  "description": "Long-term memory system for OpenClaw AI Agent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cortex-memory": "./scripts/cli.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.copyFileSync('openclaw.plugin.json','dist/openclaw.plugin.json');fs.copyFileSync('openclaw.plugin.json','src/openclaw.plugin.json')\"",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/install.js"
  },
  "keywords": [
    "openclaw",
    "memory",
    "ai",
    "agent",
    "rag"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/",
    "scripts/",
    "openclaw.plugin.json",
    "SKILL.md"
  ],
  "openclaw": {
    "plugin": true,
    "requiresPython": true,
    "cli": "cortex-memory"
  }
}
